{
  "name": "@weng-lab/genomebrowser-monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @weng-lab/genomebrowser build",
    "build:ui": "pnpm --filter @weng-lab/genomebrowser-ui build",
    "dev": "pnpm -r dev",
    "dev:core": "pnpm --filter @weng-lab/genomebrowser dev",
    "dev:ui": "pnpm --filter @weng-lab/genomebrowser-ui dev",
    "publish:core": "pnpm --filter @weng-lab/genomebrowser publish",
    "publish:ui": "pnpm --filter @weng-lab/genomebrowser-ui publish",
    "version:core": "cd packages/core && pnpm version",
    "version:ui": "cd packages/ui && pnpm version",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "prettier": "3.6.2",
    "typescript": "~5.7.3"
  },
  "dependencies": {
    "@mui/x-tree-view": "^8.18.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
